# Planetary Hello World - Update metadata
# Location is stored in journey-public.json (viewable without secret)

# Optional: Location at build time (ISO 6709, SI units)
# PHW_UPDATE_LAT=35.6762
# PHW_UPDATE_LON=139.6503
# PHW_UPDATE_ALT=40

# Optional: Encryption (PHW_UPDATE_SECRET) for update-metadata.json
# PHW_UPDATE_SECRET=your-secret-key-min-16-chars
